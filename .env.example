# 行情数据源：sample / yfinance / alpha_vantage / twelve_data
STOCK_DATA_PROVIDER=sample
ALPHA_VANTAGE_API_KEY=
TWELVE_DATA_API_KEY=

# 默认安全关闭。只填写邮箱授权码或邮件服务 API Key，禁止填写网页登录密码。
EMAIL_ENABLED=false
EMAIL_PROVIDER=resend
EMAIL_TO=you@example.com
EMAIL_FROM=Stock Sentinel <alerts@example.com>
RESEND_API_KEY=

# SMTP 备选配置（例如 smtp.qq.com:465）。SMTP_PASSWORD 应填写授权码。
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_SSL=true

# GitHub Pages 或其他 PWA 地址，会放进提醒邮件。
SITE_URL=http://localhost:5173
